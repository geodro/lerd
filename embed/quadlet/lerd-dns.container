[Unit]
Description=Lerd DNS (dnsmasq)
After=network.target

[Container]
Image=lerd-dnsmasq:local
ContainerName=lerd-dns
PublishPort=127.0.0.1:5300:5300/udp
PublishPort=127.0.0.1:5300:5300/tcp
Volume=%h/.local/share/lerd/dnsmasq:/etc/dnsmasq.d:ro
Exec=dnsmasq --no-daemon --conf-dir=/etc/dnsmasq.d

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=default.target
